# Environment Variables Example

# Facebook OAuth App ID
# Lấy từ: https://developers.facebook.com/apps/
VITE_FACEBOOK_APP_ID=3832704913701035

# Backend API URL (if needed for CORS or custom endpoints)
# VITE_API_URL=http://localhost:8080

# Google OAuth App ID (already configured in Google OAuth provider)
# VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
